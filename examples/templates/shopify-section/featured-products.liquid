{% comment %}
  Featured products section starter for Shopify Liquid practice.
{% endcomment %}

<section class="featured-products" aria-labelledby="featured-products-title">
  <div class="featured-products__header">
    <p>{{ section.settings.eyebrow | escape }}</p>
    <h2 id="featured-products-title">{{ section.settings.heading | escape }}</h2>
    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link }}" class="featured-products__link">
        {{ section.settings.button_label | escape }}
      </a>
    {% endif %}
  </div>

  <ul class="featured-products__grid" role="list">
    {% for product in section.settings.collection.products limit: section.settings.products_to_show %}
      <li class="featured-products__item">
        <a href="{{ product.url }}" class="featured-products__card">
          {% if product.featured_image %}
            {{ product.featured_image | image_url: width: 720 | image_tag: loading: 'lazy', alt: product.featured_image.alt | default: product.title }}
          {% endif %}
          <span class="featured-products__title">{{ product.title }}</span>
          <span class="featured-products__price">{{ product.price | money }}</span>
        </a>
      </li>
    {% endfor %}
  </ul>
</section>

{% schema %}
{
  "name": "Featured products starter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Fresh picks" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured products" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop collection" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Featured products starter" }]
}
{% endschema %}
